# Xcode
build/
DerivedData/
*.xcuserstate
*.xcuserdatad/
xcuserdata/
*.xccheckout
*.moved-aside

# Swift Package Manager
# Ignore SPM build artefacts but commit the workspace lockfile so a clean
# clone resolves the same Moonshine + FluidAudio versions a reviewer would
# see in our commits — exactly what `Package.resolved` is for. The bare
# `Package.resolved` ignore previously globbed both root SPM packages and
# the Xcode workspace lock; we want the workspace one tracked.
.build/
Packages/
/Package.resolved
*.xcodeproj/project.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/

# CocoaPods (we don't use, but just in case)
Pods/

# Carthage
Carthage/Build/

# Bundler / Fastlane
.bundle/
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# Models — too large for git, downloaded on first launch
Models/*.onnx
Models/*.mlpackage
Models/*.mlmodelc
Aftertalk/Models/**/*.ort
Aftertalk/Models/**/*.bin
Aftertalk/Models/**/*.onnx
Aftertalk/Models/**/*.mlpackage
Aftertalk/Models/**/*.mlmodelc
Aftertalk/Resources/Models/*
# Keep the Pyannote placeholder folder so xcodegen's folder reference resolves
# before fetch-pyannote-models.sh has been run.
!Aftertalk/Resources/Models/speaker-diarization-coreml/
Aftertalk/Resources/Models/speaker-diarization-coreml/*
!Aftertalk/Resources/Models/speaker-diarization-coreml/.keep
# Keep the Kokoro placeholder folder so xcodegen's folder reference resolves
# before fetch-kokoro-models.sh has been run.
!Aftertalk/Resources/Models/kokoro-82m-coreml/
Aftertalk/Resources/Models/kokoro-82m-coreml/*
!Aftertalk/Resources/Models/kokoro-82m-coreml/.keep

# Profiling raw outputs (chart pngs are committed)
perf/*.csv
!perf/30min-meeting-chart.png
!perf/perf-template.csv

# Golden test fixtures: keep transcripts, ignore raw audio
golden/*.wav
golden/*.m4a
golden/*.mp3

# OS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# IDE
.vscode/
.idea/

# Secrets — none in this project but being explicit
.env
.env.local
*.p12
*.mobileprovision
secrets.json
.claude/
